      "title": "Utilisation CPU pods (%)",
      "type": "gauge",
      "targets": [
        {
          "expr": "avg by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"frugal\"}[5m])) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
